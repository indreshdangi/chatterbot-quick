// backend/server.js
// Robust multi-provider chat proxy: Groq (OpenAI-compatible), Gemini (Google), OpenAI (optional).
// Written to fail loudly with helpful messages so debugging is trivial.

const express = require("express");
const cors = require("cors");
const fs = require("fs");
const path = require("path");
require("dotenv").config();
const fetch = require("node-fetch");

const app = express();
app.use(cors());
app.use(express.json({ limit: "1mb" }));

const PORT = process.env.PORT || 3000;
const PROJECT_ROOT = path.join(__dirname);
const PUBLIC_DIR = path.join(PROJECT_ROOT, "..", "public");
const DB_PATH = path.join(PROJECT_ROOT, "history.json");

// --- Env keys (read & trim)
const GROQ_KEY = (process.env.GROQ_KEY || "").trim();
const GROQ_API_BASE = (process.env.GROQ_API_BASE || "https://api.groq.com/openai/v1").trim();
const GROQ_MODEL = (process.env.GROQ_MODEL || "llama-3.1-instant-8b-128k").trim();

const GEMINI_KEY = (process.env.GEMINI_KEY || "").trim();
const GEMINI_MODEL = (process.env.GEMINI_MODEL || "gemini-2.5").trim();

const OPENAI_KEY = (process.env.OPENAI_KEY || "").trim();
const OPENAI_MODEL = (process.env.OPENAI_MODEL || "gpt-4o").trim();

// create history file if missing
if (!fs.existsSync(DB_PATH)) {
  try { fs.writeFileSync(DB_PATH, "{}"); } catch (e) { console.error("Could not create history.json:", e); }
}

// DB helpers
function loadDB() {
  try { return JSON.parse(fs.readFileSync(DB_PATH, "utf8") || "{}"); }
  catch (e) { console.error("loadDB error:", e); return {}; }
}
function saveDB(db) {
  try { fs.writeFileSync(DB_PATH, JSON.stringify(db, null, 2), "utf8"); }
  catch (e) { console.error("saveDB error:", e); }
}

// sanitize small helper
function sanitizeReply(text) {
  if (!text) return "";
  if (typeof text !== "string") text = String(text);
  // strip weird long non-ascii runs (helps display)
  text = text.replace(/[^\x00-\x7F]+/g, " ");
  return text.replace(/\s+/g, " ").trim();
}

// safe parse
async function safeParseResponse(res) {
  const ct = (res.headers && res.headers.get ? res.headers.get("content-type") : "") || "";
  try {
    if (ct.includes("application/json")) {
      const j = await res.json();
      return { ok: res.ok, json: j };
    } else {
      const t = await res.text();
      try { return { ok: res.ok, json: JSON.parse(t) }; } catch(e){ return { ok: res.ok, text: t }; }
    }
  } catch (e) {
    return { ok: false, error: e, text: null };
  }
}

/* --------- Provider callers --------- */

// GROQ (OpenAI compatible path)
async function callGroq(modelId, userMessage, opts={}) {
  if (!GROQ_KEY) throw new Error("GROQ_KEY_MISSING");
  const url = `${GROQ_API_BASE}/chat/completions`; // using openai-compatible chat endpoint
  const body = {
    model: modelId,
    messages: [{ role: "user", content: userMessage }],
    max_tokens: opts.maxOutputTokens || 512,
    temperature: typeof opts.temperature === "number" ? opts.temperature : 0.7
  };
  const resp = await fetch(url, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": `Bearer ${GROQ_KEY}`
    },
    body: JSON.stringify(body),
    // node-fetch v2 doesn't support timeout option directly; we rely on default.
  });
  const parsed = await safeParseResponse(resp);
  return { provider: "groq", resp, parsed };
}

// Gemini (Google Generative) - NOTE: many Google setups require IAM/service account + different auth.
// This attempts a simple API key query (works for some setups). If your Google setup uses OAuth/service account,
// you'll need a service account flow (not covered here).
async function callGemini(modelId, userMessage, opts={}) {
  if (!GEMINI_KEY) throw new Error("GEMINI_KEY_MISSING");
  // NOTE: some Google accounts use different endpoints. If 404 occurs, check Google console docs.
  const url = `https://generativelanguage.googleapis.com/v1beta2/models/${encodeURIComponent(modelId)}:generate?key=${GEMINI_KEY}`;
  const body = {
    prompt: { text: userMessage },
    maxOutputTokens: opts.maxOutputTokens || 512,
    temperature: typeof opts.temperature === "number" ? opts.temperature : 0.7
  };
  const resp = await fetch(url, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(body)
  });
  const parsed = await safeParseResponse(resp);
  return { provider: "gemini", resp, parsed };
}

// OpenAI direct (optional)
async function callOpenAIDirect(modelId, userMessage, opts={}) {
  if (!OPENAI_KEY) throw new Error("OPENAI_KEY_MISSING");
  const url = "https://api.openai.com/v1/chat/completions";
  const body = {
    model: modelId,
    messages: [{ role: "system", content: opts.system || "" }, { role: "user", content: userMessage }],
    max_tokens: opts.maxTokens || 800,
    temperature: typeof opts.temperature === "number" ? opts.temperature : 0.7
  };
  const resp = await fetch(url, {
    method: "POST",
    headers: { "Content-Type": "application/json", "Authorization": `Bearer ${OPENAI_KEY}` },
    body: JSON.stringify(body)
  });
  const parsed = await safeParseResponse(resp);
  return { provider: "openai", resp, parsed };
}

/* --------- Main endpoint --------- */

app.post("/api/chat", async (req, res) => {
  try {
    const message = (req.body.message || "").toString();
    const convId = req.body.conversation_id || "default";
    const modelKey = (req.body.model || "gemini_2_5").toString();

    if (!message) return res.status(400).json({ error: "message required" });

    // Persist user
    const db = loadDB();
    if (!db[convId]) db[convId] = [];
    db[convId].push({ role: "user", content: message, created_at: new Date().toISOString() });
    saveDB(db);

    // choose provider mapping
    let providerResult = null;
    let replyText = null;
    let usedProvider = null;

    try {
      if (modelKey === "llama_3_1_8b_instant") {
        // GROQ
        usedProvider = "groq";
        providerResult = await callGroq(GROQ_MODEL, message, { maxOutputTokens: 800, temperature: 0.6 });
      } else if (modelKey === "gemini_2_5") {
        usedProvider = "gemini";
        providerResult = await callGemini(GEMINI_MODEL, message, { maxOutputTokens: 800, temperature: 0.6 });
      } else if (modelKey === "gpt4o_standard") {
        usedProvider = "openai";
        providerResult = await callOpenAIDirect(OPENAI_MODEL, message, { system: "You are Indresh 2.0", maxTokens: 1000, temperature: 0.6 });
      } else {
        return res.status(400).json({ error: "unknown_model_key", detail: modelKey });
      }
    } catch (provErr) {
      console.warn("Provider call exception:", provErr);
      db[convId].push({ role: "assistant", content: `Provider error: ${String(provErr)}`, created_at: new Date().toISOString(), meta: { error: true }});
      saveDB(db);
      return res.status(502).json({ error: "provider_exception", provider: usedProvider, detail: String(provErr) });
    }

    // parse response
    const p = providerResult.parsed;
    if (p && p.json) {
      const j = p.json;
      // Common patterns
      replyText =
        j?.choices?.[0]?.message?.content ||
        j?.choices?.[0]?.text ||
        j?.output?.text ||
        j?.candidates?.[0]?.content ||
        j?.generated_text ||
        (typeof j === "string" ? j : null);
      // For Google Gen response structure might be different:
      if (!replyText && j?.candidates && j.candidates[0] && j.candidates[0].content) {
        replyText = j.candidates[0].content;
      }
      // For Google the generated text may be in j?.output?.[0] etc; fallback to raw JSON string
      if (!replyText && Object.keys(j).length === 0) {
        // empty json returned
        replyText = "";
      }
    } else if (p && p.text) {
      replyText = p.text;
    } else if (p && p.ok === false && p.error) {
      // provider returned error JSON parsed into 'error' field
      replyText = `Provider returned error: ${JSON.stringify(p.error)}`;
    }

    // If still empty try raw body (best-effort)
    if (!replyText && providerResult && providerResult.resp) {
      try {
        const raw = await providerResult.resp.text();
        if (raw && raw.length) replyText = raw;
      } catch (e) { /* ignore */ }
    }

    if (!replyText) {
      const detail = providerResult && providerResult.parsed ? (providerResult.parsed.json || providerResult.parsed.text || providerResult.parsed.error || null) : null;
      db[convId].push({ role: "assistant", content: `Provider error: no content`, created_at: new Date().toISOString(), meta: { error: true, provider: usedProvider, detail }});
      saveDB(db);
      return res.status(502).json({ error: "provider_no_content", provider: usedProvider, detail: detail || "no body" });
    }

    // sanitize and save
    replyText = sanitizeReply(replyText.replace(/OpenAI|ChatGPT/gi, "Indresh 2.0"));
    db[convId].push({ role: "assistant", content: replyText, created_at: new Date().toISOString() });
    saveDB(db);

    return res.json({ output: { role: "assistant", content: replyText, via: usedProvider } });

  } catch (err) {
    console.error("Server /api/chat error:", err);
    return res.status(500).json({ error: "server_error", details: err && err.message ? err.message : String(err) });
  }
});

// History endpoints
app.get("/api/history/:id", (req, res) => {
  const db = loadDB();
  res.json({ messages: db[req.params.id] || [] });
});
app.post("/api/clear/:id", (req, res) => {
  const db = loadDB();
  db[req.params.id] = [];
  saveDB(db);
  res.json({ ok: true });
});

// static serve
if (fs.existsSync(PUBLIC_DIR)) {
  app.use(express.static(PUBLIC_DIR));
  app.get("/", (req, res) => {
    const idx = path.join(PUBLIC_DIR, "index.html");
    if (fs.existsSync(idx)) return res.sendFile(idx);
    return res.status(404).send("index.html missing in public/");
  });
}

// Start
const server = app.listen(PORT, "127.0.0.1", () => {
  console.log(`Server running and listening on http://127.0.0.1:${PORT}`);
  console.log("PUBLIC_DIR:", PUBLIC_DIR, "exists:", fs.existsSync(PUBLIC_DIR));
  console.log("GROQ_KEY:", GROQ_KEY ? "SET len=" + GROQ_KEY.length : "MISSING");
  console.log("GROQ_API_BASE:", GROQ_API_BASE);
  console.log("GEMINI_KEY:", GEMINI_KEY ? "SET len=" + GEMINI_KEY.length : "MISSING");
  console.log("OPENAI_KEY:", OPENAI_KEY ? "SET len=" + OPENAI_KEY.length : "MISSING");
});

// graceful
process.on("SIGINT", () => {
  console.log("Shutting down...");
  server.close(() => process.exit(0));
});
// Example: instruct to answer in Hindi if user message appears to be Hindi OR user selected preference
